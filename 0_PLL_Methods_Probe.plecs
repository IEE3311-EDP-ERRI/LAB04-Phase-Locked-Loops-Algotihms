          Parameter {
            Variable      "Declarations"
            Value         "#include <complex.h>\n"
"#include <math.h>\n"
"#define mPI\t\t\t3.14159265358979323846\n"
"\n"
"#define Vam InputSignal(0,0)\n"
"#define Vaa InputSignal(0,1) \n"
"#define Vbm InputSignal(0,2) \n"
"#define Vba InputSignal(0,3) \n"
"#define Vcm InputSignal(0,4) \n"
"#define Vca InputSignal(0,5) \n"
"                             \n"
"#define Vpm OutputSignal(0,0)\n"
"#define Vpa OutputSignal(0,1)\n"
"#define Vnm OutputSignal(0,2)\n"
"#define Vna OutputSignal(0,3)\n"
"#define V0m OutputSignal(0,4)\n"
"#define V0a OutputSignal(0,5)\n"
"\n"
"\n"
"float complex a, a2;\n"
"float complex Va,Vb,Vc,Vp,Vn,V0;\n"
            Show          off
          }
          Parameter {
            Variable      "StartFcn"
            Value         "a = cexp(I*2.*mPI/3.);\n"
"a2 = a*a;"
            Show          off
          }
          Parameter {
            Variable      "OutputFcn"
            Value         "Va=Vam*cexp(I*Vaa);\n"
"Vb=Vbm*cexp(I*Vba);\n"
"Vc=Vcm*cexp(I*Vca);\n"
"\n"
"V0 = (Va + Vb    + Vc   )/3.;\n"
"Vp = (Va + Vb*a  + Vc*a2)/3.;\n"
"Vn = (Va + Vb*a2 + Vc*a )/3.;\n"
"\n"
"V0m = cabs(V0);\n"
"V0a = carg(V0);\n"
"Vpm = cabs(Vp);\n"
"Vpa = carg(Vp);\n"
"Vnm = cabs(Vn);\n"
"Vna = carg(Vn);"
            Show          off
          }
