  InitializationCommands "%%%%%%%%%%%%%%%%%%%%%%%%%%%%%\nTs = 1/10000 ; \n%fsw"
" = 10000 ; \n\n% DC Voltage\n%Vdc = 700 ;\n\n% Modulation Indexes\n%ma = 1.0 "
"; \n%mf = 400 ; \n\n% Sinusoidal reference\nVpeak = 220*sqrt(2) ;\nfreq = 50 "
";\n%w_g = 2*pi*freq ; \n\n%Harmoinc Inyection\nh5=0.15*Vpeak;\nh7=0.1*Vpeak\n"
"\n% Carrier \n%Vcr = Vdc ;\n%fcr = mf*freq ;\n%fsw = fcr ; \n\n\n% Filter \n%"
"Lf = 2e-3 ; \n%Rf = 10e-3 ; \n\n%R_load = 10 ; \n\n% Controlador iL\n%wn_iL ="
" 2*pi*300 ; \n%xi_iL = 0.707 ; \n%Kp_iL = 2*xi_iL*wn_iL*Lf - Rf ; \n%Ki_iL = "
"(wn_iL*wn_iL)*Lf ; \n%Vd_max = Vdc*1.0 ; \n\n\n\n\n\n\n"
